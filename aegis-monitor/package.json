{
  "private": true,
  "scripts": {
    "build": "esbuild monitor/static/src/vendor.js --bundle --outfile=monitor/static/vendor-sigma.min.js --format=iife --minify",
    "build:dev": "esbuild monitor/static/src/vendor.js --bundle --outfile=monitor/static/vendor-sigma.min.js --format=iife",
    "dev": "npm run build && uvicorn monitor.app:app --host 0.0.0.0 --port 8080 --reload",
